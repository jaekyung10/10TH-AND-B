<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <ImageView
        android:id="@+id/iv_bag"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/ic_bag"
        android:contentDescription="장바구니 아이콘"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tv_cart_message"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="240dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tv_cart_message"
        android:layout_width="332dp"
        android:layout_height="wrap_content"
        android:text="장바구니가 비어 있습니다.\n제품을 추가하면 여기에 표시됩니다."
        android:textSize="14sp"
        android:textColor="#000000"
        android:gravity="center"
        android:lineSpacingExtra="2dp"
        app:layout_constraintTop_toBottomOf="@id/iv_bag"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btn_order"
        android:layout_width="0dp"
        android:layout_height="51dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="36dp"
        android:text="주문하기"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#000000"
        app:cornerRadius="26dp"
        app:layout_constraintBottom_toTopOf="@id/main_bottom_space"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <View
        android:id="@+id/main_bottom_space"
        android:layout_width="0dp"
        android:layout_height="56dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>